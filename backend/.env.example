# Configuration du serveur
PORT=5000

# Configuration de la base de données PostgreSQL
# Sur Render, utilisez plutôt DATABASE_URL fourni par le dashboard
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=ebookingsam
DB_PASSWORD=postgres
DB_PORT=5432
DATABASE_URL=postgres://user:password@host:5432/dbname

# Clé secrète JWT (à changer en production)
# Pour générer une nouvelle clé, exécutez : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-please-replace-it

# Configuration Email (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Configuration Stripe (optionnel)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Mode d'environnement
NODE_ENV=development
